generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  TUTOR
  ADMIN
}

enum GrantStatus {
  ELIGIBLE
  RISK
  DENIED
}

enum DecisionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  LATE
  MISSED
}

enum AchievementType {
  ACADEMIC
  INNOVATION
  LANGUAGE
  SOCIAL
  SPORT
  LEADERSHIP
  RESEARCH
  COMPETITION
  VOLUNTEERING
}

enum RecordStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PenaltyType {
  ATTENDANCE
  ASSIGNMENT
  DISCIPLINE
  ACADEMIC
  OTHER
}

enum RecoveryStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EmploymentType {
  INTERNSHIP
  PART_TIME
  FULL_TIME
  RESEARCH_ASSISTANT
}

enum EmploymentStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
}

enum FeedbackType {
  ASSIGNMENT
  ACTIVITY
  TUTOR
  DISCIPLINE
  GENERAL
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  EXPELLED
}

model User {
  id                     String                 @id @default(cuid())
  fullName               String
  email                  String                 @unique
  phone                  String?
  passwordHash           String
  role                   Role                   @default(STUDENT)
  avatarUrl              String?
  externalId             String?                @unique
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  studentProfile         StudentProfile?
  mentorProfile          MentorProfile?
  tutorProfile           TutorProfile?
  mentorStudents         StudentProfile[]       @relation("MentorStudents")
  tutorStudents          StudentProfile[]       @relation("TutorStudents")
  approvedAchievements   Achievement[]          @relation("AchievementApprover")
  createdPenalties       Penalty[]              @relation("PenaltyCreator")
  assignedRecoveryTasks  RecoveryTask[]         @relation("RecoveryAssigner")
  authoredFeedbacks      Feedback[]             @relation("FeedbackAuthor")
  approvedGrantDecisions GrantDecision[]        @relation("GrantDecisionApprover")
  statusChanges          StudentProfile[]       @relation("StudentStatusChanger")
  scoreAdjustments       AdminScoreAdjustment[] @relation("AdminScoreAdjustmentAuthor")

  @@index([role, isActive])
}

model StudentProfile {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  mentorId              String?
  tutorId               String?
  studentId             String                 @unique
  groupName             String
  faculty               String
  level                 String
  grantType             String
  currentGpaPercent     Decimal                @default(0) @db.Decimal(5, 2)
  status                StudentStatus          @default(ACTIVE)
  statusReason          String?
  statusChangedAt       DateTime?
  statusChangedById     String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentor                User?                  @relation("MentorStudents", fields: [mentorId], references: [id], onDelete: SetNull)
  tutor                 User?                  @relation("TutorStudents", fields: [tutorId], references: [id], onDelete: SetNull)
  statusChangedBy       User?                  @relation("StudentStatusChanger", fields: [statusChangedById], references: [id], onDelete: SetNull)
  scoreRecords          ScoreRecord[]
  attendanceRecords     AttendanceRecord[]
  assignmentRecords     AssignmentRecord[]
  achievements          Achievement[]
  penalties             Penalty[]
  recoveryTasks         RecoveryTask[]
  employments           Employment[]
  feedbacks             Feedback[]
  grantDecisions        GrantDecision[]
  adminScoreAdjustments AdminScoreAdjustment[]

  @@index([faculty, groupName])
  @@index([mentorId])
  @@index([tutorId])
  @@index([status])
}

model MentorProfile {
  id         String @id @default(cuid())
  userId     String @unique
  department String
  specialty  String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorProfile {
  id            String @id @default(cuid())
  userId        String @unique
  assignedGroup String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreRecord {
  id              String         @id @default(cuid())
  studentId       String
  semester        String
  academicPercent Decimal        @db.Decimal(5, 2)
  academicScore   Decimal        @db.Decimal(5, 2)
  attendanceScore Decimal        @db.Decimal(5, 2)
  assignmentScore Decimal        @db.Decimal(5, 2)
  activityScore   Decimal        @db.Decimal(5, 2)
  tutorScore      Decimal        @db.Decimal(5, 2)
  disciplineScore Decimal        @db.Decimal(5, 2)
  mainKpi         Decimal        @db.Decimal(5, 2)
  penaltyScore    Decimal        @db.Decimal(5, 2)
  recoveryScore   Decimal        @db.Decimal(5, 2)
  employmentBonus Decimal        @db.Decimal(5, 2)
  adminBonusScore Decimal        @default(0) @db.Decimal(5, 2)
  finalScore      Decimal        @db.Decimal(5, 2)
  riskLevel       RiskLevel
  grantStatus     GrantStatus
  calculatedAt    DateTime       @default(now())
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semester])
  @@index([grantStatus, riskLevel])
  @@index([finalScore])
}

model AdminScoreAdjustment {
  id        String         @id @default(cuid())
  studentId String
  adminId   String
  score     Decimal        @db.Decimal(5, 2)
  reason    String
  createdAt DateTime       @default(now())
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  admin     User           @relation("AdminScoreAdjustmentAuthor", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([studentId, createdAt])
  @@index([adminId])
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  studentId  String
  date       DateTime
  time       String?
  status     AttendanceStatus
  subject    String?
  subjectId  String?
  reason     String?
  note       String?
  student    StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectRef Subject?         @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([studentId, date])
  @@index([status])
  @@index([subjectId])
}

model Subject {
  id                String             @id @default(cuid())
  subjectId         String             @unique
  name              String
  teacher           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]

  @@index([teacher])
}

model AssignmentRecord {
  id              String           @id @default(cuid())
  studentId       String
  subject         String
  title           String
  score           Decimal          @db.Decimal(5, 2)
  status          AssignmentStatus @default(PENDING)
  submittedOnTime Boolean          @default(false)
  isOriginal      Boolean          @default(true)
  qualityNote     String?
  deadline        DateTime
  submittedAt     DateTime?
  student         StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([deadline])
}

model Achievement {
  id           String          @id @default(cuid())
  studentId    String
  approvedById String?
  type         AchievementType
  title        String
  description  String?
  score        Decimal         @db.Decimal(5, 2)
  status       RecordStatus    @default(PENDING)
  proofUrl     String?
  createdAt    DateTime        @default(now())
  student      StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy   User?           @relation("AchievementApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@index([approvedById])
}

model Penalty {
  id          String         @id @default(cuid())
  studentId   String
  createdById String
  type        PenaltyType
  reason      String
  score       Decimal        @db.Decimal(5, 2)
  createdAt   DateTime       @default(now())
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("PenaltyCreator", fields: [createdById], references: [id])

  @@index([studentId, createdAt])
  @@index([createdById])
}

model RecoveryTask {
  id            String         @id @default(cuid())
  studentId     String
  assignedById  String
  title         String
  description   String?
  recoveryScore Decimal        @db.Decimal(5, 2)
  status        RecoveryStatus @default(ASSIGNED)
  deadline      DateTime
  completedAt   DateTime?
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy    User           @relation("RecoveryAssigner", fields: [assignedById], references: [id])

  @@index([studentId, status])
  @@index([assignedById])
  @@index([deadline])
}

model Employment {
  id          String           @id @default(cuid())
  studentId   String
  type        EmploymentType
  companyName String
  position    String
  bonusScore  Decimal          @db.Decimal(5, 2)
  proofUrl    String?
  status      EmploymentStatus @default(PENDING)
  student     StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([type])
}

model Feedback {
  id        String         @id @default(cuid())
  studentId String
  authorId  String
  message   String
  type      FeedbackType
  subject   String?
  grade     Decimal?       @db.Decimal(3, 1)
  score     Decimal?       @db.Decimal(5, 2)
  createdAt DateTime       @default(now())
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  author    User           @relation("FeedbackAuthor", fields: [authorId], references: [id])

  @@index([studentId, authorId])
  @@index([type])
}

model GrantDecision {
  id           String         @id @default(cuid())
  studentId    String
  approvedById String
  semester     String
  status       DecisionStatus
  finalScore   Decimal        @db.Decimal(5, 2)
  reason       String?
  createdAt    DateTime       @default(now())
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy   User           @relation("GrantDecisionApprover", fields: [approvedById], references: [id])

  @@index([studentId, semester])
  @@index([approvedById])
  @@index([status])
}
